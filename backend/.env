# Backend environment (local development)
BACKEND_ENVIRONMENT=development
BACKEND_LOG_LEVEL=INFO

# Service settings
BACKEND_CORS_ORIGINS=*
BACKEND_SOCKETIO_PATH=/realtime

# Database and Redis
BACKEND_DATABASE_URL=postgresql+asyncpg://localhost/trading_backend
BACKEND_REDIS_URL=redis://localhost:6379/0

# Credential encryption (Fernet key)
# Generate with: python backend/scripts/generate_fernet_key.py
BACKEND_CREDENTIALS_KEY=Ys4VyQ6_RcVlEbycNxbHAug24Dx5ClmQKqrnESGoXiM=

# Prompt image uploads
BACKEND_PROMPT_IMAGE_UPLOADER=filesystem  # filesystem or imgbb
BACKEND_PROMPT_IMAGE_STORE_PATH=backend/tmp/prompt_images
BACKEND_PROMPT_IMAGE_BASE_URL=
BACKEND_PROMPT_IMAGE_UPLOAD_CONCURRENCY=4
BACKEND_PROMPT_IMAGE_IMGBB_API_KEY=
BACKEND_PROMPT_IMAGE_IMGBB_API_URL=https://api.imgbb.com/1/upload
BACKEND_PROMPT_IMAGE_FREEIMAGE_API_KEY=
BACKEND_PROMPT_IMAGE_FREEIMAGE_API_URL=https://freeimage.host/api/1/upload

# LLM caller (OpenAI-compatible)
BACKEND_LLM_BASE_URL=https://api.openai.com/v1
BACKEND_LLM_API_KEY=
BACKEND_LLM_MODEL=gpt-4o
BACKEND_LLM_TEMPERATURE=0.7
BACKEND_LLM_MAX_TOKENS=1024
BACKEND_CODEX_CLI_PATH=codex
BACKEND_CODEX_CLI_TIMEOUT_SECONDS=600
BACKEND_CODEX_TEMP_IMAGE_PATH=backend/tmp/codex_images
BACKEND_CODEX_TEMP_IMAGE_TTL_MINUTES=60
BACKEND_CODEX_TEMP_IMAGE_SWEEP_INTERVAL_SECONDS=600

# Binance REST tuning
BACKEND_BINANCE_HTTP_TIMEOUT_SECONDS=20
BACKEND_BINANCE_HTTP_POOL_TIMEOUT_SECONDS=60
BACKEND_BINANCE_HTTP_MAX_KEEPALIVE_CONNECTIONS=50
BACKEND_BINANCE_HTTP_MAX_CONNECTIONS=200
BACKEND_BINANCE_MAX_REQUESTS_PER_SECOND=5
BACKEND_BINANCE_MAX_CONCURRENCY=2
BACKEND_BINANCE_RETRY_COUNT=2
BACKEND_BINANCE_RETRY_BASE_DELAY=0.5
BACKEND_BINANCE_RETRY_MAX_DELAY=4.0
BACKEND_BINANCE_RETRY_JITTER=0.3
BACKEND_BINANCE_RATE_LIMIT_BACKOFF=15.0
